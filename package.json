{
  "name": "webmux",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,server \"cd packages/web && pnpm dev\" \"cd packages/server && WEBMUX_DEV_MODE=true JWT_SECRET=dev-secret pnpm dev\"",
    "build": "pnpm -r build",
    "typecheck": "tsc -b",
    "lint": "eslint packages/",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  }
}
