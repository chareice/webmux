{
  "name": "webmux",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @webmux/shared build && pnpm --filter @webmux/app dev:web",
    "dev:web": "pnpm --filter @webmux/shared build && pnpm --filter @webmux/app dev:web",
    "dev:android": "pnpm --filter @webmux/shared build && pnpm --filter @webmux/app android",
    "build": "pnpm --filter @webmux/shared build && pnpm --filter @webmux/app build",
    "build:web": "pnpm --filter @webmux/shared build && pnpm --filter @webmux/app build:web",
    "typecheck": "pnpm --filter @webmux/shared build && pnpm --filter @webmux/app exec tsc --noEmit",
    "lint": "eslint packages/",
    "test": "pnpm --filter @webmux/shared build && pnpm --filter @webmux/app test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.9",
    "@rolldown/binding-darwin-x64": "1.0.0-rc.9",
    "@rolldown/binding-linux-arm64-gnu": "1.0.0-rc.9",
    "@rolldown/binding-wasm32-wasi": "1.0.0-rc.9",
    "@rolldown/binding-win32-arm64-msvc": "1.0.0-rc.9",
    "@rolldown/binding-win32-x64-msvc": "1.0.0-rc.9"
  }
}
