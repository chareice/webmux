{
  "name": "@webmux/app",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "build": "expo export --platform web",
    "build:web": "expo export --platform web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "test": "NODE_NO_WARNINGS=1 node --test --experimental-strip-types $(find lib -name '*.test.ts' -print)"
  },
  "dependencies": {
    "@webmux/shared": "workspace:*",
    "expo": "~55.0.8",
    "expo-application": "^55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.10",
    "expo-image-picker": "^55.0.13",
    "expo-linking": "~55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~14.2.3",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~6.0.7",
    "nativewind": "^4.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.83.2",
    "react-native-css-interop": "0.2.3",
    "react-native-markdown-display": "^7.0.2",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/node": "^24.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.1.11",
    "tailwindcss": "^3.4.19"
  }
